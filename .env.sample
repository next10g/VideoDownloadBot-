# Get TOKEN from @BotFather — never commit real .env to git
TOKEN=123456789:ABCdefGHIjkLMNopqRSTuvwxyz
# MongoDB Atlas — replace PASSWORD (URL-encode if it has @ # % etc.)
MONGO=mongodb+srv://username:PASSWORD@cluster.mongodb.net/video-download-bot?retryWrites=true&w=majority
ENVIRONMENT=production
# Your numeric Telegram user ID (NOT @username) — get from @userinfobot
ADMIN_ID=123456789
BOT_API_URL=https://api.telegram.org
WEBHOOK_URL=https://bot.yourdomain.com
WEBHOOK_SECRET=use-a-long-random-secret-min-16-chars
PORT=3000

# Rate limits
USER_COOLDOWN_SECONDS=45
MAX_USER_ACTIVE_JOBS=1
USER_FAILURE_BLOCK_THRESHOLD=5
USER_BLOCK_MINUTES=30

# Timeouts (ms)
DOWNLOAD_TIMEOUT_MS=600000
UPLOAD_TIMEOUT_MS=600000
YTDLP_PROBE_TIMEOUT_MS=60000
QUEUE_JOB_TIMEOUT_MS=900000
QUEUE_MAX_RETRIES=1

# Content limits
MAX_FILE_SIZE_MB=350
MAX_DURATION_SECONDS=3600
AVG_JOB_DURATION_SECONDS=120

# Upload
UPLOAD_MAX_RETRIES=3
UPLOAD_RETRY_BASE_MS=2000

# Memory / temp
LOW_MEMORY_MODE=auto
LOW_MEMORY_THRESHOLD_MB=150
TEMP_CLEANUP_INTERVAL_MS=300000
TEMP_MAX_AGE_MS=3600000
SKIP_THUMBNAILS=false
# Leave empty to use ./bin/yt-dlp (recommended on Hostinger). /tmp may be noexec.
YTDLP_PATH=
# Hostinger: Python 3.10+ path if auto-detect fails, e.g. /opt/alt/alt-python311/bin/python3.11
YTDLP_PYTHON=
SKIP_YTDLP_PROBE=false
SOFT_YTDLP_PROBE=true

# Security (comma-separated, leave empty to disable)
BLACKLIST_DOMAINS=
DISALLOWED_EXTRACTORS=
SUSPICIOUS_EXTRACTORS=

# Forced subscription (optional)
REQUIRED_CHANNEL_ENABLED=false
REQUIRED_CHANNEL=@your_channel
REQUIRED_CHANNEL_LINK=https://t.me/your_channel
