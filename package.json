{
  "name": "video-download-bot",
  "version": "1.0.0",
  "description": "Telegram bot to download videos",
  "main": "dist/app.js",
  "repository": "https://github.com/Borodutch/VideoDownloadBot",
  "author": "Nour Mohamed (@Dev_Nour_M)",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "distribute": "node dist/app.js",
    "develop": "tsc-watch --skipLibCheck --onSuccess \"node dist/app.js\"",
    "build": "npm run build-ts",
    "build-ts": "tsc --skipLibCheck",
    "hostinger:install": "node scripts/hostinger-install.js",
    "hostinger:build": "node scripts/hostinger-build.js",
    "postinstall": "node scripts/ensure-ytdlp.js",
    "rebuild-sharp": "npm rebuild sharp",
    "pretty": "prettier --check src",
    "lint": "npm run pretty && eslint --max-warnings 0 --ext ts,tsx,json src"
  },
  "dependencies": {
    "@grammyjs/i18n": "^0.5.0",
    "@grammyjs/menu": "^1.0.4",
    "@typegoose/typegoose": "^9.3.1",
    "archiver": "^8.0.0",
    "envalid": "^7.2.2",
    "grammy": "^1.5.3",
    "grammy-middlewares": "^1.0.11",
    "mongoose": "^6.1.1",
    "mongoose-findorcreate": "^3.0.0",
    "sharp": "^0.33.5",
    "undici": "^6.25.0",
    "youtube-dl-exec": "^3.1.7"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.19.0",
    "dotenv": "^10.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-no-relative-import-paths": "^1.0.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "module-alias": "^2.2.2",
    "prettier": "^2.5.1",
    "source-map-support": "^0.5.21",
    "tsc-watch": "^4.5.0",
    "typescript": "^4.5.3"
  },
  "_moduleAliases": {
    "@": "dist"
  }
}
